  <node componentName="tJava" componentVersion="0.101" offsetLabelX="0" offsetLabelY="0" posX="240" posY="120">
    <elementParameter field="TEXT" name="UNIQUE_NAME" value="tJava_1" show="false"/>
    <elementParameter field="MEMO_JAVA" name="CODE" value="String[] meses = {&quot;Enero&quot;,&quot;Febrero&quot;,&quot;Marzo&quot;,&quot;Abril&quot;,&quot;Mayo&quot;,&quot;Junio&quot;,&#xA;                  &quot;Julio&quot;,&quot;Agosto&quot;,&quot;Septiembre&quot;,&quot;Octubre&quot;,&quot;Noviembre&quot;,&quot;Diciembre&quot;};&#xA;&#xA;java.io.FileWriter fw = new java.io.FileWriter(&#xA;    &quot;C:/Program Files (x86)/Talend-Studio/studio/workspace/dim_tiempo.csv&quot;&#xA;);&#xA;java.io.BufferedWriter bw = new java.io.BufferedWriter(fw);&#xA;&#xA;int id = 1;&#xA;for(int anio = 2020; anio &lt;= 2026; anio++) {&#xA;    int mesFin = (anio == 2026) ? 6 : 12;&#xA;    for(int mes = 1; mes &lt;= mesFin; mes++) {&#xA;        String fecha = anio + &quot;-&quot; + String.format(&quot;%02d&quot;, mes) + &quot;-01&quot;;&#xA;        String anioMes = anio + &quot;-&quot; + String.format(&quot;%02d&quot;, mes);&#xA;        int trimestre = (mes-1)/3 + 1;&#xA;        int semestre = mes &lt;= 6 ? 1 : 2;&#xA;        String mesNombre = meses[mes-1];&#xA;        &#xA;        bw.write(id + &quot;,&quot; + fecha + &quot;,&quot; + anio + &quot;,&quot; + mes + &quot;,&quot; + &#xA;                 mesNombre + &quot;,&quot; + anioMes + &quot;,&quot; + trimestre + &quot;,&quot; + semestre);&#xA;        bw.newLine();&#xA;        id++;&#xA;    }&#xA;}&#xA;&#xA;bw.close();&#xA;fw.close();&#xA;System.out.println(&quot;>>> CSV generado con &quot; + (id-1) + &quot; filas&quot;);"/>
    <elementParameter field="MEMO_IMPORT" name="IMPORT" value="//import java.util.List;"/>
    <elementParameter field="TEXT" name="CONNECTION_FORMAT" value="row"/>
    <metadata connector="FLOW" name="tJava_1"/>
  </node>
