<?xml version="1.0" encoding="UTF-8"?>
<talendfile:ProcessType xmi:version="2.0" xmlns:xmi="http://www.omg.org/XMI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:TalendMapper="http://www.talend.org/mapper" xmlns:talendfile="platform:/resource/org.talend.model/model/TalendFile.xsd" defaultContext="Default" jobType="Standard">
  <context confirmationNeeded="false" hide="false" name="Default">
    <contextParameter comment="" name="periodo_proceso" prompt="periodo_proceso?" promptNeeded="false" repositoryContextId="built-in" type="id_String" value="" internalId="_HmTCUDFfEfGLGOaJQJ7zyw"/>
    <contextParameter comment="" name="query_fact" prompt="query_fact?" promptNeeded="false" repositoryContextId="built-in" type="id_String" value="&quot;SELECT&#xD;&#xA;  CAST(ROW_NUMBER() OVER (ORDER BY t.fecha, p.id_pais, i.id_indicador) AS STRING) as id_hecho,&#xD;&#xA;  t.id_tiempo,&#xD;&#xA;  p.id_pais,&#xD;&#xA;  i.id_indicador,&#xD;&#xA;  f.id_fuente,&#xD;&#xA;  base.valor,&#xD;&#xA;  base.es_provisional,&#xD;&#xA;  CAST(CURRENT_TIMESTAMP() AS STRING) as fecha_carga&#xD;&#xA;FROM (&#xD;&#xA;&#xD;&#xA;  -- World Bank&#xD;&#xA;  SELECT&#xD;&#xA;    CONCAT(anio, '-01-01') as fecha_join,&#xD;&#xA;    pais_codigo as iso2,&#xD;&#xA;    CASE indicador_codigo&#xD;&#xA;      WHEN 'NY.GDP.MKTP.KD.ZG' THEN 'WB_PIB_CRECIMIENTO'&#xD;&#xA;      WHEN 'FP.CPI.TOTL.ZG' THEN 'WB_INFLACION'&#xD;&#xA;      WHEN 'SL.UEM.TOTL.ZS' THEN 'WB_DESEMPLEO'&#xD;&#xA;    END as cod_indicador,&#xD;&#xA;    'WB' as sigla_fuente,&#xD;&#xA;    valor,&#xD;&#xA;    es_nulo_origen as es_provisional&#xD;&#xA;  FROM `project-aa284588-b856-4049-937.dsa_ecuador.stg_worldbank`&#xD;&#xA;  WHERE valor IS NOT NULL AND valor != ''&#xD;&#xA;&#xD;&#xA;  UNION ALL&#xD;&#xA;&#xD;&#xA;  -- BCE IPC&#xD;&#xA;  SELECT CAST(fecha AS STRING), 'EC', 'BCE_IPC_INDICE', 'BCE',&#xD;&#xA;    CAST(ipc_indice AS STRING), 'false'&#xD;&#xA;  FROM `project-aa284588-b856-4049-937.dsa_ecuador.stg_bce_ipc`&#xD;&#xA;  WHERE ipc_indice IS NOT NULL&#xD;&#xA;&#xD;&#xA;  UNION ALL&#xD;&#xA;&#xD;&#xA;  SELECT CAST(fecha AS STRING), 'EC', 'BCE_IPC_VAR_ANUAL', 'BCE',&#xD;&#xA;    CAST(variacion_anual_pct AS STRING), 'false'&#xD;&#xA;  FROM `project-aa284588-b856-4049-937.dsa_ecuador.stg_bce_ipc`&#xD;&#xA;  WHERE variacion_anual_pct IS NOT NULL&#xD;&#xA;&#xD;&#xA;  UNION ALL&#xD;&#xA;&#xD;&#xA;  SELECT CAST(fecha AS STRING), 'EC', 'BCE_IPC_VAR_MENSUAL', 'BCE',&#xD;&#xA;    CAST(variacion_mensual_pct AS STRING), 'false'&#xD;&#xA;  FROM `project-aa284588-b856-4049-937.dsa_ecuador.stg_bce_ipc`&#xD;&#xA;  WHERE variacion_mensual_pct IS NOT NULL&#xD;&#xA;&#xD;&#xA;  UNION ALL&#xD;&#xA;&#xD;&#xA;  -- BCE Balanza&#xD;&#xA;  SELECT CAST(fecha AS STRING), 'EC', 'BCE_EXPORTACIONES', 'BCE',&#xD;&#xA;    CAST(exportaciones_fob_musd AS STRING), 'false'&#xD;&#xA;  FROM `project-aa284588-b856-4049-937.dsa_ecuador.stg_bce_balanza`&#xD;&#xA;  WHERE exportaciones_fob_musd IS NOT NULL&#xD;&#xA;&#xD;&#xA;  UNION ALL&#xD;&#xA;&#xD;&#xA;  SELECT CAST(fecha AS STRING), 'EC', 'BCE_IMPORTACIONES', 'BCE',&#xD;&#xA;    CAST(importaciones_fob_musd AS STRING), 'false'&#xD;&#xA;  FROM `project-aa284588-b856-4049-937.dsa_ecuador.stg_bce_balanza`&#xD;&#xA;  WHERE importaciones_fob_musd IS NOT NULL&#xD;&#xA;&#xD;&#xA;  UNION ALL&#xD;&#xA;&#xD;&#xA;  SELECT CAST(fecha AS STRING), 'EC', 'BCE_BALANZA', 'BCE',&#xD;&#xA;    CAST(balanza_comercial_musd AS STRING), 'false'&#xD;&#xA;  FROM `project-aa284588-b856-4049-937.dsa_ecuador.stg_bce_balanza`&#xD;&#xA;  WHERE balanza_comercial_musd IS NOT NULL&#xD;&#xA;&#xD;&#xA;  UNION ALL&#xD;&#xA;&#xD;&#xA;  -- BCE Tasas&#xD;&#xA;  SELECT CAST(fecha AS STRING), 'EC', 'BCE_TASA_CORPORATIVO', 'BCE',&#xD;&#xA;    CAST(tasa_activa_corporativo_pct AS STRING), 'false'&#xD;&#xA;  FROM `project-aa284588-b856-4049-937.dsa_ecuador.stg_bce_tasas`&#xD;&#xA;  WHERE tasa_activa_corporativo_pct IS NOT NULL&#xD;&#xA;&#xD;&#xA;  UNION ALL&#xD;&#xA;&#xD;&#xA;  SELECT CAST(fecha AS STRING), 'EC', 'BCE_TASA_CONSUMO', 'BCE',&#xD;&#xA;    CAST(tasa_consumo_pct AS STRING), 'false'&#xD;&#xA;  FROM `project-aa284588-b856-4049-937.dsa_ecuador.stg_bce_tasas`&#xD;&#xA;  WHERE tasa_consumo_pct IS NOT NULL&#xD;&#xA;&#xD;&#xA;  UNION ALL&#xD;&#xA;&#xD;&#xA;  -- INEC Empleo&#xD;&#xA;  SELECT CAST(fecha AS STRING), 'EC',&#xD;&#xA;    CASE indicador&#xD;&#xA;      WHEN 'Empleo Adecuado/Pleno (%)' THEN 'INEC_EMPLEO_ADECUADO'&#xD;&#xA;      WHEN 'Subempleo (%)' THEN 'INEC_SUBEMPLEO'&#xD;&#xA;      WHEN 'Desempleo (%)' THEN 'INEC_DESEMPLEO'&#xD;&#xA;      WHEN 'Participación Global (%)' THEN 'INEC_PARTICIPACION'&#xD;&#xA;    END,&#xD;&#xA;    'INEC',&#xD;&#xA;    CAST(valor_nacional_pct AS STRING),&#xD;&#xA;    CAST(cambio_metodologico AS STRING)&#xD;&#xA;  FROM `project-aa284588-b856-4049-937.dsa_ecuador.stg_inec_empleo`&#xD;&#xA;  WHERE fecha >= '2020-01-01'&#xD;&#xA;  AND indicador IN (&#xD;&#xA;    'Empleo Adecuado/Pleno (%)',&#xD;&#xA;    'Subempleo (%)',&#xD;&#xA;    'Desempleo (%)',&#xD;&#xA;    'Participación Global (%)'&#xD;&#xA;  )&#xD;&#xA;  AND valor_nacional_pct IS NOT NULL&#xD;&#xA;&#xD;&#xA;  UNION ALL&#xD;&#xA;&#xD;&#xA;  -- INEC Canasta&#xD;&#xA;  SELECT CAST(fecha AS STRING), 'EC', 'INEC_COSTO_CANASTA', 'INEC',&#xD;&#xA;    CAST(costo_canasta_usd AS STRING), 'false'&#xD;&#xA;  FROM `project-aa284588-b856-4049-937.dsa_ecuador.stg_inec_canasta`&#xD;&#xA;  WHERE fecha >= '2020-01-01'&#xD;&#xA;  AND costo_canasta_usd IS NOT NULL&#xD;&#xA;&#xD;&#xA;  UNION ALL&#xD;&#xA;&#xD;&#xA;  SELECT CAST(fecha AS STRING), 'EC', 'INEC_INGRESO_FAMILIAR', 'INEC',&#xD;&#xA;    CAST(ingreso_familiar_usd AS STRING), 'false'&#xD;&#xA;  FROM `project-aa284588-b856-4049-937.dsa_ecuador.stg_inec_canasta`&#xD;&#xA;  WHERE fecha >= '2020-01-01'&#xD;&#xA;  AND ingreso_familiar_usd IS NOT NULL&#xD;&#xA;&#xD;&#xA;) base&#xD;&#xA;JOIN `project-aa284588-b856-4049-937.dwh_ecuador.dim_tiempo` t&#xD;&#xA;  ON t.fecha = CAST(base.fecha_join AS DATE)&#xD;&#xA;JOIN `project-aa284588-b856-4049-937.dwh_ecuador.dim_pais` p&#xD;&#xA;  ON p.codigo_iso2 = base.iso2&#xD;&#xA;JOIN `project-aa284588-b856-4049-937.dwh_ecuador.dim_indicador` i&#xD;&#xA;  ON i.codigo_indicador = base.cod_indicador&#xD;&#xA;JOIN `project-aa284588-b856-4049-937.dwh_ecuador.dim_fuente` f&#xD;&#xA;  ON f.sigla = base.sigla_fuente&quot;" internalId="_bWoRoDIBEfGJ8P1TPCxqjA"/>
  </context>
